{
    "name": "@sigx/monaco-editor",
    "version": "0.5.0",
    "description": "Pluggable Monaco editor wrapper for sigx with prebundled assets and a Vite plugin that bypasses bundler optimization",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./vite": {
            "import": "./dist/vite-plugin.js",
            "types": "./dist/vite-plugin.d.ts"
        },
        "./shiki": {
            "import": "./dist/shiki/index.js",
            "types": "./dist/shiki/index.d.ts"
        },
        "./languages/typescript": {
            "import": "./dist/languages/typescript.js",
            "types": "./dist/languages/typescript.d.ts"
        },
        "./languages/html": {
            "import": "./dist/languages/html.js",
            "types": "./dist/languages/html.d.ts"
        },
        "./languages/css": {
            "import": "./dist/languages/css.js",
            "types": "./dist/languages/css.d.ts"
        },
        "./languages/json": {
            "import": "./dist/languages/json.js",
            "types": "./dist/languages/json.d.ts"
        },
        "./monaco-bundle/*": {
            "import": "./public/monaco-bundle/*"
        }
    },
    "files": [
        "dist",
        "src",
        "public"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "bundle:monaco": "tsx scripts/bundle-monaco.ts"
    },
    "keywords": [
        "sigx",
        "monaco",
        "monaco-editor",
        "code-editor",
        "vite-plugin"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/monaco-editor.git",
        "directory": "packages/monaco-editor"
    },
    "homepage": "https://sigx.dev/monaco/",
    "bugs": {
        "url": "https://github.com/signalxjs/monaco-editor/issues"
    },
    "peerDependencies": {
        "monaco-editor": ">=0.50.0",
        "sigx": "catalog:",
        "vite": ">=5.0.0"
    },
    "peerDependenciesMeta": {
        "monaco-editor": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "@shikijs/monaco": "^3.7.0",
        "shiki": "^3.7.0"
    },
    "devDependencies": {
        "@shikijs/langs": "^3.21.0",
        "@shikijs/monaco": "^3.7.0",
        "@shikijs/themes": "^3.21.0",
        "@sigx/vite": "catalog:",
        "@types/node": "^22.19.1",
        "esbuild": "^0.28.1",
        "monaco-editor": "^0.56.0",
        "shiki": "^3.7.0",
        "sigx": "catalog:",
        "tsx": "^4.23.1",
        "typescript": "^5.9.3",
        "vite": "^8.1.5"
    }
}
