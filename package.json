{
    "name": "sigx-monaco-editor-monorepo",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "description": "Monorepo for @sigx/monaco-editor — a pluggable Monaco wrapper for sigx",
    "type": "module",
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "build": "pnpm --filter @sigx/monaco-editor run build",
        "bundle:monaco": "pnpm --filter @sigx/monaco-editor run bundle:monaco",
        "dev:basic": "pnpm --filter @sigx-example/monaco-basic run dev",
        "typecheck": "tsgo --noEmit",
        "lint": "oxlint packages/monaco-editor/src",
        "lint:fix": "oxlint --fix packages/monaco-editor/src",
        "publish:dry": "node scripts/publish.js --dry-run",
        "publish:all": "node scripts/publish.js",
        "publish:beta": "node scripts/publish.js --tag beta",
        "verify:pack": "node scripts/verify-pack.js",
        "version:set": "node scripts/bump-version.js",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major",
        "size": "size-limit",
        "clean": "node -e \"const fs=require('fs'),p=require('path');const rm=x=>fs.rmSync(x,{recursive:true,force:true});for(const d of fs.readdirSync('packages')){rm(p.join('packages',d,'dist'));rm(p.join('packages',d,'node_modules'));}rm('node_modules');rm('pnpm-lock.yaml');\""
    },
    "devDependencies": {
        "@size-limit/preset-small-lib": "^11",
        "@typescript/native-preview": "7.0.0-dev.20260508.1",
        "oxlint": "^1.63.0",
        "size-limit": "^11",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5"
    },
    "keywords": [
        "sigx",
        "signalx",
        "monaco",
        "monaco-editor",
        "code-editor"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/monaco-editor.git"
    },
    "homepage": "https://github.com/signalxjs/monaco-editor",
    "bugs": {
        "url": "https://github.com/signalxjs/monaco-editor/issues"
    }
}
